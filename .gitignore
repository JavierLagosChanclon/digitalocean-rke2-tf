# Terraform directories and files
**/.terraform/*
**/terraform-provider*/*
*.tfstate
*.tfstate.*
*.terraform*
crash.log

# Files that may contain secrets
terraform.tfvars
*kube_config.yml*
*kubeconfig.yaml*
*-ssh_private_key.pem*
*-ssh_public_key.pem*
suse-observability-values/templates/affinity_values.yaml
suse-observability-values/templates/baseConfig_values.yaml
suse-observability-values/templates/sizing_values.yaml
suse-observability-values/templates/ingress_values.yaml

# Ignore generated OS images to avoid committing large build artifacts
**/*.iso
**/*.vhd
**/*.qcow2.bz2
**/*.tar.gz

# Temporary files
**/*.swp
.DS_Store
